{
  "name": "databook",
  "version": "0.1.0",
  "description": "An AI-editable SQL database app via MCP. The MCP server IS the app — its tool definitions encode the product decisions.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "databook": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && shx cp -r dist mcp-server/",
    "build:renderer": "cd electron/renderer && npx vite build",
    "dev": "run-p dev:ts dev:renderer dev:electron",
    "dev:ts": "tsc --watch",
    "dev:renderer": "cd electron/renderer && npx vite",
    "dev:electron": "wait-on http://localhost:5173 && electron electron/main.cjs",
    "start": "node dist/index.js",
    "rebuild:electron": "npx @electron/rebuild -m .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "better-sqlite3": "^11.9.1",
    "chokidar": "^4.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^34.0.0",
    "npm-run-all2": "^8.0.4",
    "shx": "^0.3.4",
    "typescript": "^5.8.2",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
